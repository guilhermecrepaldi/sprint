# Copie este arquivo para .env e preencha

# Chave da API Anthropic (claude-opus-4-5 para avaliação)
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp via CallMeBot (gratuito — veja: callmebot.com/blog/free-api-whatsapp-messages)
WA_PHONE=5511999999999        # seu número com DDI (sem + e sem espaços)
WA_APIKEY=                    # apikey recebida pelo WhatsApp após ativar

# Telegram Bot (alternativa gratuita e mais confiável)
TG_BOT_TOKEN=                 # token do @BotFather
TG_CHAT_ID=                   # seu chat_id (número)
